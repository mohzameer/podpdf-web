---
import { getCollection, type CollectionEntry } from 'astro:content';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Icon } from 'astro-icon/components';
import { formatDate } from '@/lib/utils';
import { siteConfig } from '@/config';

type BlogEntry = CollectionEntry<'blog'>;

const allPosts = await getCollection('blog', ({ data }: { data: BlogEntry['data'] }) => !data.draft);

allPosts.sort((a: BlogEntry, b: BlogEntry) =>
  b.data.publishedDate.getTime() - a.data.publishedDate.getTime()
);

const tagCounts = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
const topTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 8).map(([tag]) => tag);

const featured = allPosts[0];
const rest = allPosts.slice(1);
---

<MarketingLayout
  title={`Blog — ${siteConfig.name}`}
  description="Tips, guides, and deep dives on PDF generation, automation, HTML-to-PDF conversion, and integrating PodPDF into your workflows."
>
  <!-- Hero -->
  <section class="py-section bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl sm:text-5xl font-bold text-text">Blog</h1>
        <p class="mt-4 text-lg text-text-muted">
          Guides, tutorials, and insights on PDF generation, document automation, and integrating PodPDF into your workflows.
        </p>
      </div>
    </div>
  </section>

  <!-- Featured Post -->
  {featured && (
    <section class="py-12 border-b border-border">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-semibold text-primary uppercase tracking-widest mb-6">Featured Post</p>
        <a
          href={`/blog/${featured.id}`}
          class="group grid grid-cols-1 lg:grid-cols-2 gap-8 rounded-xl border border-border bg-background hover:border-primary hover:shadow-lg transition-all p-8"
        >
          <div class="flex flex-col justify-center">
            <div class="flex flex-wrap gap-2 mb-4">
              {featured.data.tags.map((tag: string) => (
                <span class="px-3 py-1 text-xs font-medium bg-primary/10 text-primary rounded-full">{tag}</span>
              ))}
            </div>
            <h2 class="text-2xl sm:text-3xl font-bold text-text group-hover:text-primary transition-colors leading-tight">
              {featured.data.title}
            </h2>
            <p class="mt-3 text-text-muted leading-relaxed">
              {featured.data.description}
            </p>
            <div class="mt-6 flex items-center gap-4 text-sm text-text-muted">
              <span class="flex items-center gap-1">
                <Icon name="lucide:user" class="w-4 h-4" />
                {featured.data.author}
              </span>
              <span class="flex items-center gap-1">
                <Icon name="lucide:calendar" class="w-4 h-4" />
                {formatDate(featured.data.publishedDate)}
              </span>
            </div>
            <div class="mt-6 flex items-center gap-2 text-primary font-medium">
              Read article
              <Icon name="lucide:arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
            </div>
          </div>
          <div class="flex items-center justify-center rounded-lg bg-gradient-to-br from-primary/10 to-primary/5 min-h-[200px] lg:min-h-0">
            <Icon name="lucide:file-text" class="w-24 h-24 text-primary/30" />
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- Tags -->
  {topTags.length > 0 && (
    <section class="py-8 border-b border-border">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-wrap items-center gap-3">
          <span class="text-sm font-medium text-text-muted">Topics:</span>
          {topTags.map((tag) => (
            <span class="px-3 py-1 text-sm bg-surface border border-border text-text-muted rounded-full hover:border-primary hover:text-primary transition-colors cursor-default">
              {tag}
            </span>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Post Grid -->
  {rest.length > 0 && (
    <section class="py-section">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-text mb-8">All Posts</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {rest.map((post: BlogEntry) => (
            <a
              href={`/blog/${post.id}`}
              class="group flex flex-col rounded-xl border border-border bg-background hover:border-primary hover:shadow-md transition-all p-6"
            >
              <div class="flex flex-wrap gap-2 mb-4">
                {post.data.tags.slice(0, 2).map((tag: string) => (
                  <span class="px-2 py-0.5 text-xs font-medium bg-surface text-text-muted rounded-full">{tag}</span>
                ))}
              </div>
              <h3 class="text-lg font-semibold text-text group-hover:text-primary transition-colors leading-snug flex-1">
                {post.data.title}
              </h3>
              <p class="mt-2 text-sm text-text-muted line-clamp-3">
                {post.data.description}
              </p>
              <div class="mt-4 flex items-center gap-3 text-xs text-text-muted border-t border-border pt-4">
                <span class="flex items-center gap-1">
                  <Icon name="lucide:calendar" class="w-3.5 h-3.5" />
                  {formatDate(post.data.publishedDate)}
                </span>
                <span class="flex items-center gap-1 ml-auto text-primary font-medium text-sm">
                  Read
                  <Icon name="lucide:arrow-right" class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" />
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-section bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl font-bold text-text">Ready to generate your first PDF?</h2>
        <p class="mt-3 text-text-muted">Start with 100 free PDFs — no credit card required.</p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="https://app.podpdf.com/signup"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-md bg-primary text-white font-medium hover:bg-primary-dark transition-colors"
          >
            <Icon name="lucide:zap" class="w-5 h-5" />
            Start Free
          </a>
          <a
            href="https://apidocs.podpdf.com"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-md border border-border bg-background text-text font-medium hover:bg-surface transition-colors"
          >
            <Icon name="lucide:code" class="w-5 h-5" />
            View API Docs
          </a>
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>
