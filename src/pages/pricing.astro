---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PricingTable from '@sections/pricing/PricingTable.astro';
import ComparisonTable from '@sections/pricing/ComparisonTable.astro';
import TrustBadges from '@sections/pricing/TrustBadges.astro';
import FAQSection from '@sections/content/FAQSection.astro';
import CTA from '@sections/marketing/CTA.astro';
import { siteConfig } from '@/config';

const planNames = ['Pay As You Go', 'Custom'];

const plans = [
  {
    name: 'Pay As You Go',
    monthlyPrice: null,
    customPrice: '$0.01 per PDF',
    description: 'For production use and automation',
    features: [
      'Unlimited PDFs (subject to credit balance)',
      'Web app + Full API access',
      'No rate limits',
      '$0.01 per PDF (credit-based billing, purchase credits upfront)',
      'Credits never expire',
      'HTML, Markdown & Images',
      'Priority support',
      'Permanent job history retention',
      '5 Webhooks',
      'Webhook Delivery History',
      'Unlimited API keys',
    ],
    highlighted: true,
    cta: { label: 'Get Started', href: 'https://app.podpdf.com/signup' },
  },
  {
    name: 'Custom',
    monthlyPrice: null,
    customPrice: "Let's Talk",
    description: 'Tailored for startups scaling up to enterprise needs',
    features: [
      'Volume discounts on high PDF usage',
      'Monthly invoice billing (NET-30)',
      'Dedicated account manager',
      'Custom contracts',
      'Priority 24/7 support',
      'Custom integrations & onboarding',
      'Up to 50 webhook configurations',
      'Unlimited API keys',
      'White-label options available',
    ],
    highlighted: false,
    cta: { label: 'Contact Sales', href: 'mailto:podpdfapp@gmail.com' },
  },
];

const faqs = [
  {
    question: 'Can I use both the web app and API?',
    answer:
      "Yes! Both methods are included and count toward the same credit balance. Use the web app for manual conversions and the API for automation—whatever works best for your workflow.",
  },
  {
    question: 'How does credit-based billing work?',
    answer:
      "Purchase credits upfront ($0.01 per PDF), and they're deducted after each PDF generation. You must have sufficient credits to generate PDFs. Credits never expire.",
  },
  {
    question: 'Is there a free trial?',
    answer:
      "PodPDF is a paid-only service. All accounts require a credit purchase to get started. There is no free tier.",
  },
  {
    question: 'Are there any rate limits?',
    answer:
      'The Pay As You Go plan has no API rate limits. The web app has no rate limits either.',
  },
  {
    question: 'Do I need coding skills?',
    answer:
      "Not at all! Use our visual web application with drag-and-drop—no coding required. Developers can use our API for automation.",
  },
  {
    question: 'What input formats do you support?',
    answer:
      "Both the web app and API support HTML, Markdown, and images.",
  },
  {
    question: 'What happens if I run out of credits?',
    answer:
      "If you have insufficient credits, PDF generation requests will be rejected with an INSUFFICIENT_CREDITS error. Purchase more credits through your dashboard to continue.",
  },
  {
    question: 'Do credits expire?',
    answer:
      "No. Credits remain in your account until you use them — there is no expiry date.",
  },
];

const comparisonCategories = [
  {
    name: 'Usage Limits',
    features: [
      { name: 'PDF Quota', values: ['Unlimited (credit-based)', 'Unlimited (volume discounts)'] },
      { name: 'Billing Model', values: ['Credit-based ($0.01/PDF)', 'Custom (monthly invoice)'] },
      { name: 'Rate Limit', values: ['Unlimited', 'Unlimited'] },
      { name: 'API Keys', values: ['Unlimited', 'Unlimited'] },
      { name: 'Credits Expire', values: ['Never', 'Never'] },
    ],
  },
  {
    name: 'Input Formats',
    features: [
      { name: 'HTML to PDF', values: [true, true] },
      { name: 'Markdown to PDF', values: [true, true] },
      { name: 'Images to PDF', values: [true, true] },
      { name: 'Content Size Limit', values: ['5 MB', '5 MB'] },
      { name: 'Page Limit', values: ['100', '100+'] },
    ],
  },
  {
    name: 'Features',
    features: [
      { name: 'Dashboard Access', values: [true, true] },
      { name: 'Job History', values: ['Permanent', 'Permanent'] },
      { name: 'Webhooks', values: ['5 webhooks', 'Up to 50 webhooks'] },
      { name: 'Webhook Events', values: ['Event subscriptions', 'Event subscriptions'] },
      { name: 'Webhook History', values: [true, true] },
    ],
  },
  {
    name: 'Support',
    features: [
      { name: 'Documentation', values: [true, true] },
      { name: 'Email Support', values: ['Priority Email', 'Dedicated'] },
    ],
  },
];
---

<MarketingLayout
  title={`Pricing - ${siteConfig.name}`}
  description="Simple, credit-based pricing. Pay only $0.01 per PDF — no subscriptions, no monthly minimums, no hidden costs. Credits never expire."
>
  <PricingTable
    title="Simple, transparent pricing"
    subtitle="Use the web app or API — both count toward the same balance. Pay only $0.01 per PDF. No subscriptions, no monthly minimums. Credits never expire."
    plans={plans}
    annualDiscount={0}
    defaultPeriod="monthly"
  />

  <TrustBadges
    guarantee={{
      title: 'Pay only for what you use',
      description:
        'Purchase credits upfront at $0.01 per PDF. Credits never expire. No monthly fees, no surprise charges.',
    }}
  />

  <ComparisonTable
    title="Compare plans in detail"
    subtitle="See exactly what's included in each plan."
    plans={planNames}
    categories={comparisonCategories}
    highlightedPlan={0}
    background="default"
  />

  <FAQSection
    title="Frequently asked questions"
    faqs={faqs}
    variant="simple"
    background="default"
  />

  <CTA
    title="Need high-volume pricing or custom features?"
    description="Generating thousands of PDFs? Need dedicated support or custom integrations? Let's talk about Enterprise pricing tailored to your needs."
    action={{ label: 'Contact Sales', href: 'https://app.podpdf.com/signup' }}
    background="muted"
  />
</MarketingLayout>
