---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Hero from '@sections/marketing/Hero.astro';
import HowItWorks from '@sections/marketing/HowItWorks.astro';
import FeaturesSection from '@sections/marketing/FeaturesSection.astro';
import BentoGrid from '@sections/marketing/BentoGrid.astro';
import PricingTable from '@sections/pricing/PricingTable.astro';
import CTA from '@sections/marketing/CTA.astro';
import { siteConfig } from '@/config';


const bentoItems = [
  {
    title: 'Powerful REST API',
    description: 'A clean, well-documented RESTful API that works in any language or framework. Automate PDF generation from HTML, Markdown, or images with just a few lines of code. Full programmatic control over every PDF setting.',
    icon: 'lucide:code',
    size: 'large' as const,
    accent: 'primary' as const,
  },
  {
    title: 'Any Language, Any Stack',
    description: 'Node.js, Python, PHP, Ruby, Go—if it can make an HTTP request, it works with PodPDF.',
    icon: 'lucide:layers',
    accent: 'blue' as const,
  },
  {
    title: 'Real-Time Dashboard',
    description: 'Monitor API jobs, track conversion history, and manage API keys from one place.',
    icon: 'lucide:activity',
    accent: 'green' as const,
  },
  {
    title: 'Webhook Notifications',
    description:
      'Event-driven automation built in. Subscribe to job.completed, job.failed, job.timeout, and more. Multiple webhook endpoints, delivery history, and retry logic. Perfect for async pipelines.',
    icon: 'lucide:bell',
    size: 'medium' as const,
    accent: 'purple' as const,
  },
];

const features = [
  {
    icon: 'lucide:code',
    title: 'Simple REST API',
    description:
      'Clean endpoints, clear docs, and SDKs for every major language. Integrate in minutes.',
  },
  {
    icon: 'lucide:zap',
    title: 'Lightning Fast',
    description:
      'Under 30 seconds per conversion. Serverless infrastructure scales with your load instantly.',
  },
  {
    icon: 'lucide:dollar-sign',
    title: 'Incredibly Affordable',
    description:
      '$0.01 per PDF. No monthly fees, no seat licenses—pay only for what you generate.',
  },
  {
    icon: 'lucide:sliders',
    title: 'Full Customization',
    description:
      'Control page size, margins, headers, footers, and more through simple API parameters.',
  },
  {
    icon: 'lucide:bell',
    title: 'Webhook-Ready',
    description:
      'Async jobs with webhook callbacks. Build event-driven pipelines without polling.',
  },
  {
    icon: 'lucide:shield',
    title: 'Enterprise Security',
    description:
      'AWS infrastructure, API key auth, and TLS everywhere. Production-grade from day one.',
  },
];

const pricingPlans = [
  {
    name: 'Pay As You Go',
    monthlyPrice: null,
    customPrice: '$0.01/PDF',
    description: 'For production applications',
    features: [
      'Unlimited PDFs',
      'Web app + Full API access',
      'No rate limits',
      '$0.01 per PDF',
      'Credits never expire',
      'Priority support',
      '5 Webhooks',
    ],
    highlighted: true,
    cta: { label: 'Get Started', href: 'https://app.podpdf.com/signup' },
  },
  {
    name: 'Custom',
    monthlyPrice: null,
    customPrice: "Let's Talk",
    description: 'Volume discounts and monthly invoice billing',
    features: ['$0.01 per PDF — same rate', 'Monthly invoice billing (NET-30)', 'Dedicated account manager', 'Custom contracts', 'Up to 50 webhooks'],
    cta: { label: 'Contact Sales', href: 'mailto:podpdfapp@gmail.com' },
  },
];
---

<MarketingLayout
  title="PodPDF - PDF Generation API for Automation"
  description={siteConfig.description}
>
  <Hero
    title="Automate PDF Generation — or Convert Right in the App"
    subtitle="PodPDF gives you two ways to make professional PDFs from HTML, Markdown, or images. Wire up the REST API to automate generation at scale, or skip the code entirely and convert directly in the built-in app — paste, upload, and download in seconds. Any language, $0.01 per PDF. No subscriptions, no monthly minimums — credits never expire. Need a custom integration? Talk to us and we'll make it happen."
    primaryCTA={{ label: 'Open the Converter', href: 'https://app.podpdf.com/convert' }}
    secondaryCTA={{ label: 'Get Started Free', href: 'https://app.podpdf.com/signup' }}
    contactEmail="podpdfapp@gmail.com"
  />


  <HowItWorks
    id="how-it-works"
    title="Production-ready in minutes"
    subtitle="A few lines of code is all it takes to start generating PDFs at scale."
    steps={[
      {
        title: 'Sign up',
        description:
          'Create your account at app.podpdf.com',
        icon: 'lucide:user-plus',
      },
      {
        title: 'Purchase credits',
        description:
          'Buy credits upfront — they never expire',
        icon: 'lucide:credit-card',
      },
      {
        title: 'Generate PDFs at scale',
        description: 'Professional results in under 30 seconds',
        icon: 'lucide:file-check',
      },
    ]}
    variant="horizontal"
    background="muted"
  />


  <FeaturesSection
    title="Everything you need to automate PDF generation"
    subtitle="A reliable, affordable API with the features developers actually need—webhooks, full customization, and zero ops overhead."
    features={features}
    background="muted"
    footerLink={undefined}
  />

  <BentoGrid
    title="Built for Developers, Designed for Scale"
    subtitle="Everything you need to automate PDF generation—powerful API, webhooks, and real-time monitoring—all on reliable cloud infrastructure."
    items={bentoItems}
    background="muted"
  />

  <PricingTable
    title="Simple, transparent pricing"
    subtitle="No monthly fees — pay only per PDF generated. Credits never expire."
    plans={pricingPlans}
    annualDiscount={0}
    background="default"
    footerLink={{ label: 'View full pricing details →', href: '/pricing' }}
  />

  <CTA
    title="Ready to automate PDF generation?"
    description="A powerful, easy-to-integrate API for developers and teams building at scale. Purchase credits and start generating in minutes."
    action={{ label: 'Get Started', href: 'https://app.podpdf.com/signup' }}
  />
</MarketingLayout>
